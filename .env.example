# Copy to .env and fill in. Never commit real secrets.
# See docs/miniapp-setup.md, docs/telegram-webhook-setup.md, bot/wechat-setup.md.

# Instance
GRACE_MAR_USER_ID=grace-mar

# Mini App / LLM (apps/miniapp_server.py)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
PORT=5000

# Inference provider (optional; see docs/inference-modes.md)
# LLM_PROVIDER=openai          # openai | ollama | edge

# Telegram (optional; webhook on same service as miniapp)
TELEGRAM_BOT_TOKEN=
WEBHOOK_BASE_URL=
# On Render, RENDER_EXTERNAL_URL is set automatically.

# Operator fetch / gate review (optional)
OPERATOR_FETCH_SECRET=
OPERATOR_SECRET=

# GitHub (optional; merge-from-browser, PR flows)
GITHUB_TOKEN=
GRACE_MAR_REPO=rbtkhn/grace-mar

# Profile / menu URL for bot button
PROFILE_MINIAPP_URL=

# Family hub (optional)
FAMILY_APP_TOKEN=

# Work-politics dashboard (optional) — prefer POL_*; WAP_* still read for backward compatibility
POL_DASHBOARD_TOKEN=
POL_JOBS_PATH=
WAP_DASHBOARD_TOKEN=
WAP_JOBS_PATH=

# WeChat (optional; see bot/wechat-setup.md)
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# Civilization Memory (optional; bot/lookup_cmc.py also checks research/repos/civilization_memory/ and ../civilization_memory)
# CIVILIZATION_MEMORY_PATH=../civilization_memory

# Escape hatch only if paths intentionally incomplete
# GRACE_MAR_SKIP_PATH_CHECK=1
