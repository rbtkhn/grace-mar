{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rbtkhn/companion-self/schema-registry/seed-constitution.v1.json",
  "title": "seed_constitution",
  "description": "Instance constitution synthesized from seed-phase scaffolds (governance + optional self-critique protocol).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "user_slug",
    "principles",
    "hierarchy",
    "self_critique_protocol",
    "source_scaffolds"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "user_slug": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "prompt_cache_friendly": {
      "type": "boolean"
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "why"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "hierarchy": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "string",
        "const": "memory_contract"
      },
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "self_critique_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critique_prompt_template",
        "revision_prompt_template",
        "max_revision_steps",
        "output_format"
      ],
      "properties": {
        "critique_prompt_template": {
          "type": "string",
          "minLength": 1
        },
        "revision_prompt_template": {
          "type": "string",
          "minLength": 1
        },
        "max_revision_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "output_format": {
          "type": "string",
          "enum": [
            "json",
            "text"
          ]
        }
      }
    },
    "source_scaffolds": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
