{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema-registry/forecast-artifact.v1.json",
  "title": "Forecast Artifact v1",
  "type": "object",
  "required": [
    "artifact_type",
    "version",
    "series_name",
    "time_unit",
    "history_window",
    "forecast_horizon",
    "forecast_generated_at",
    "method",
    "point_forecast",
    "assumptions",
    "invalidators"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "forecast_artifact"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "series_name": {
      "type": "string"
    },
    "series_description": {
      "type": "string"
    },
    "time_unit": {
      "type": "string",
      "enum": [
        "day",
        "week",
        "month",
        "quarter",
        "year",
        "custom"
      ]
    },
    "history_window": {
      "type": "object",
      "required": [
        "start",
        "end",
        "n_observations"
      ],
      "properties": {
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "n_observations": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "forecast_horizon": {
      "type": "integer",
      "minimum": 1
    },
    "forecast_generated_at": {
      "type": "string"
    },
    "method": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "config": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "point_forecast": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "quantile_forecast": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    },
    "covariates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "benchmark_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "baseline_name"
        ],
        "properties": {
          "baseline_name": {
            "type": "string"
          },
          "mae": {
            "type": [
              "number",
              "null"
            ]
          },
          "rmse": {
            "type": [
              "number",
              "null"
            ]
          },
          "mape": {
            "type": [
              "number",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "invalidators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "operator_note": {
      "type": "string"
    },
    "receipt_id": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_methods": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    }
  },
  "additionalProperties": false
}
