{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/strategy-day-proposal.v1.json",
  "title": "Strategy day proposal (sidecar, v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "target_date",
    "thesis",
    "mode",
    "target_file",
    "references",
    "approval_required"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "target_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "thesis": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "days_only",
        "carry"
      ]
    },
    "target_file": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_required": {
      "type": "boolean"
    }
  }
}
