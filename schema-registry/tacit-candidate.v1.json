{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/tacit-candidate.v1.json",
  "title": "Grace-Mar Tacit-Derived Candidate (non-canonical)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_type",
    "title",
    "distilled_claim",
    "rationale",
    "supporting_excerpts",
    "proposed_destination_surface",
    "confidence",
    "review_questions",
    "provenance_tacit_id",
    "provenance_normalized_path",
    "generator_version"
  ],
  "properties": {
    "candidate_type": {
      "type": "string",
      "enum": [
        "skill_candidate",
        "library_candidate",
        "work_doctrine_candidate",
        "moonshot_insight_candidate"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "distilled_claim": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "supporting_excerpts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proposed_destination_surface": { "type": "string", "minLength": 1 },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "review_questions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "provenance_tacit_id": { "type": "string", "minLength": 1 },
    "provenance_normalized_path": { "type": "string", "minLength": 1 },
    "generator_version": { "type": "string", "const": "1.0" }
  }
}
