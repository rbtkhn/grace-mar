{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/change-review-queue.v1.json",
  "title": "Companion-Self Change Review Queue v1",
  "description": "Canonical queue surface for governed change proposals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "userSlug",
    "queueGeneratedAt",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "userSlug": {
      "type": "string",
      "minLength": 1
    },
    "queueGeneratedAt": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposalId",
          "status",
          "priority",
          "summary",
          "proposalClass",
          "targetSurface",
          "materiality",
          "reviewType",
          "riskLevel",
          "requiresReclassification"
        ],
        "properties": {
          "proposalId": {
            "type": "string",
            "pattern": "^proposal-[a-zA-Z0-9._-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "under_review",
              "approved",
              "deferred",
              "rejected",
              "superseded"
            ]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "proposalClass": {
            "type": "string",
            "enum": ["identity", "library", "skills", "evidence", "policy", "work_politics"]
          },
          "targetSurface": {
            "type": "string",
            "enum": ["self", "self_library", "civ_mem", "skills", "evidence", "work_layer"]
          },
          "materiality": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "reviewType": {
            "type": "string",
            "enum": ["routine", "extended", "boundary", "policy", "collision"]
          },
          "riskLevel": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "requiresReclassification": {
            "type": "boolean",
            "default": false
          },
          "canonicalPath": {
            "type": "string",
            "minLength": 1
          },
          "evidenceCount": {
            "type": "integer",
            "minimum": 0
          },
          "confidenceAfter": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
