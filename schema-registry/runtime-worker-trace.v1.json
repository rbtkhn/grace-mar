{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/runtime-worker-trace.v1.json",
  "title": "Grace-Mar Runtime Worker Trace (non-canonical)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "timestamp",
    "task_mode",
    "scope",
    "tools_used",
    "approvals_requested",
    "outputs",
    "boundary_checks",
    "status",
    "provenance"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "task_mode": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "tools_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approvals_requested": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "boundary_checks": {
      "type": "object",
      "additionalProperties": true
    },
    "status": { "type": "string", "enum": ["ok", "error", "partial"] },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "error": { "type": ["string", "null"] }
  }
}
