{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rbtkhn/companion-self/schema-registry/seed-pedagogy.v1.json",
  "title": "seed_pedagogy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "user_slug",
    "pedagogy",
    "confidence",
    "issues"
  ],
  "properties": {
    "user_slug": {
      "type": "string",
      "minLength": 1
    },
    "pedagogy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explanation_style",
        "scaffolding_method",
        "difficulty_ramp",
        "correction_style",
        "encouragement_rules",
        "anti_spoonfeeding_rules"
      ],
      "properties": {
        "explanation_style": {
          "type": "string"
        },
        "scaffolding_method": {
          "type": "string"
        },
        "difficulty_ramp": {
          "type": "string"
        },
        "correction_style": {
          "type": "string"
        },
        "encouragement_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "anti_spoonfeeding_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": [
        "pedagogy_confidence"
      ],
      "properties": {
        "pedagogy_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
