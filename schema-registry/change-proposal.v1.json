{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/change-proposal.v1.json",
  "title": "Companion-Self Change Proposal v1",
  "description": "Structured proposal for a materially important governed change after seed-phase activation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "proposalId",
    "userSlug",
    "createdAt",
    "primaryScope",
    "changeType",
    "priorStateRef",
    "proposedStateRef",
    "supportingEvidence",
    "riskLevel",
    "status",
    "targetSurface",
    "materiality",
    "reviewType",
    "queueSummary"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "proposalId": {
      "type": "string",
      "pattern": "^proposal-[a-zA-Z0-9._-]+$"
    },
    "userSlug": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "primaryScope": {
      "type": "string",
      "enum": [
        "identity",
        "curiosity",
        "pedagogy",
        "expression",
        "memory_governance",
        "safety",
        "preference",
        "upgrade_collision"
      ]
    },
    "secondaryScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "identity",
          "curiosity",
          "pedagogy",
          "expression",
          "memory_governance",
          "safety",
          "preference",
          "upgrade_collision"
        ]
      },
      "uniqueItems": true,
      "default": []
    },
    "changeType": {
      "type": "string",
      "enum": [
        "contradiction",
        "refinement",
        "expansion",
        "deprecation",
        "ambiguity",
        "policy_collision",
        "template_instance_collision"
      ]
    },
    "priorStateRef": {
      "type": "string",
      "minLength": 1
    },
    "proposedStateRef": {
      "type": "string",
      "minLength": 1
    },
    "supportingEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "ref", "summary"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "interaction",
              "seed_artifact",
              "template_upgrade",
              "manual_note",
              "policy_signal",
              "validation_output"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "confidenceDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "after": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "under_review",
        "approved",
        "deferred",
        "rejected",
        "superseded"
      ]
    },
    "notes": {
      "type": "string"
    },
    "targetSurface": {
      "type": "string",
      "enum": ["self", "self_library", "civ_mem", "skills", "evidence", "work_layer"]
    },
    "suggestedSurface": {
      "type": "string",
      "enum": ["self", "self_library", "civ_mem", "skills", "evidence", "work_layer"]
    },
    "canonicalPath": {
      "type": "string",
      "minLength": 1
    },
    "materiality": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "reviewType": {
      "type": "string",
      "enum": ["routine", "extended", "boundary", "policy", "collision"]
    },
    "boundaryStatus": {
      "type": "string",
      "enum": ["clear", "ambiguous", "misfiled_suspected"]
    },
    "requiresReclassification": {
      "type": "boolean",
      "default": false
    },
    "queueSummary": {
      "type": "string",
      "minLength": 1
    },
    "proposalClass": {
      "type": "string",
      "enum": ["identity", "library", "skills", "evidence", "policy", "work_politics"]
    }
  }
}
