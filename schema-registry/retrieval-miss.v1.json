{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/retrieval-miss.v1.json",
  "title": "Grace-Mar Retrieval Miss",
  "description": "Non-canonical observability record for retrieval failures. Not Record truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "miss_id",
    "timestamp",
    "retrieval_surface",
    "query",
    "failure_class"
  ],
  "properties": {
    "miss_id": {
      "type": "string",
      "pattern": "^rmiss_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{8}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "retrieval_surface": {
      "type": "string",
      "enum": [
        "prepared_context",
        "evidence_lookup",
        "artifact_lookup",
        "notebook_lookup"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "expected_target": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "vocabulary_mismatch",
        "scope_mismatch",
        "stale_ranking",
        "missing_content",
        "aggregation_failure",
        "unknown"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1000
    },
    "related_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "lane_or_context": {
      "type": [
        "string",
        "null"
      ]
    },
    "recorded_by": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
