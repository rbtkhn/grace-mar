{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-registry/recursion-gate-provenance.v1.json",
  "title": "RECURSION-GATE optional provenance extension",
  "description": "Optional YAML keys for candidates staged with runtime observation lineage. Companion merge still required.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_observation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timeline_anchor": {
      "type": "string"
    },
    "compression_artifact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "lane_origin": {
      "type": "string"
    },
    "supporting_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradiction_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
