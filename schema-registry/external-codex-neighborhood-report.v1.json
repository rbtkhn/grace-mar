{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema-registry/external-codex-neighborhood-report.v1.json",
  "title": "External Codex Neighborhood Report v1",
  "description": "Grace-mar derived structural neighborhood of a path inside a checked-out civilization_memory (or similar) repo — WORK receipt only, not semantic truth.",
  "type": "object",
  "required": [
    "report_type",
    "schema_version",
    "report_id",
    "generated_at",
    "checkout_relative",
    "subject_relative",
    "subject_kind",
    "builder_version",
    "neighbor_limit",
    "neighbors",
    "truncated",
    "likely_family",
    "suggested_next_inspection"
  ],
  "additionalProperties": true,
  "properties": {
    "report_type": {
      "type": "string",
      "const": "external_codex_neighborhood_report"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "report_id": {
      "type": "string",
      "description": "Stable identifier for this report (e.g. hash of inputs + timestamp)."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when the report was produced."
    },
    "checkout_relative": {
      "type": "string",
      "description": "Checkout root path relative to grace-mar repo root (posix slashes)."
    },
    "checkout_absolute": {
      "type": "string",
      "description": "Absolute resolved checkout path on the machine that built the report (optional)."
    },
    "subject_relative": {
      "type": "string",
      "description": "Subject path relative to checkout root (posix slashes)."
    },
    "subject_kind": {
      "type": "string",
      "enum": ["file", "directory"]
    },
    "subject_title": {
      "type": ["string", "null"],
      "description": "First markdown H1 line from subject file when applicable."
    },
    "builder_version": {
      "type": "string",
      "description": "Builder script semantic version."
    },
    "neighbor_limit": {
      "type": "integer",
      "minimum": 1
    },
    "truncated": {
      "type": "boolean",
      "description": "True if neighbor list was capped by neighbor_limit."
    },
    "likely_family": {
      "type": "object",
      "description": "Heuristic subject-family summary for operators (non-authoritative).",
      "additionalProperties": true
    },
    "suggested_next_inspection": {
      "type": "array",
      "description": "Deterministic top-K paths for follow-up reads.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path_relative": { "type": "string" },
          "reason": { "type": "string" },
          "score": { "type": "integer" }
        }
      }
    },
    "neighbors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path_relative", "edge"],
        "additionalProperties": true,
        "properties": {
          "path_relative": {
            "type": "string",
            "description": "Path relative to checkout (posix slashes)."
          },
          "edge": {
            "type": "string",
            "enum": ["same_directory", "parent_directory"],
            "description": "Structural relation heuristic only."
          },
          "reason": {
            "type": "string",
            "description": "Mechanical explanation string."
          },
          "section": {
            "type": "string",
            "description": "Grouping bucket key for Markdown companion."
          },
          "file_class": {
            "type": "string"
          },
          "civilization_token": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal notices (e.g. skipped .git)."
    }
  }
}
