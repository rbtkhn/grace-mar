{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grace-mar.local/schemas/mcp-local-index-request.v1.json",
  "title": "McpLocalIndexRequest",
  "$comment": "Local repo-scoped read-only directory index — scripts/mcp_local_index.py",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "request": { "$ref": "#/$defs/request" }
  },
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "declared_intent",
        "path",
        "recursive",
        "max_depth",
        "include_file_hashes",
        "include_line_counts",
        "max_entries"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "declared_intent": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "recursive": { "type": "boolean" },
        "max_depth": { "type": "integer", "minimum": 0, "maximum": 5 },
        "include_file_hashes": { "type": "boolean" },
        "include_line_counts": { "type": "boolean" },
        "max_entries": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    }
  }
}
