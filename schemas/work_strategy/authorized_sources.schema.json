{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "work_strategy_authorized_sources",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "status": { "type": "string", "enum": ["active", "draft", "deprecated"] },
    "scope": { "type": "string" },
    "lane": { "type": "string" },
    "purpose": { "type": "string" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promotion_eligible": {},
        "transcript_rule": { "type": "string" },
        "historical_use_rule": { "type": "string" },
        "neutral_summary_rule": { "type": "string" }
      }
    },
    "source_classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "typical_uses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "promotion_default": {}
        }
      }
    },
    "artifact_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "preferred_classes": { "type": "array", "items": { "type": "string" } },
          "allowed_classes": { "type": "array", "items": { "type": "string" } },
          "caution_classes": { "type": "array", "items": { "type": "string" } },
          "disallow_as_sole_basis": { "type": "array", "items": { "type": "string" } },
          "caution_note": { "type": "string" }
        }
      }
    },
    "ssot_note": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "source_class",
          "lane_relevance",
          "trust_tier",
          "update_cadence",
          "last_reviewed",
          "promotion_eligible"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string" },
          "source_class": {
            "type": "string",
            "enum": ["primary", "data", "reporting", "analyst", "transcript", "operator_note"]
          },
          "lane_relevance": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "trust_tier": { "type": "integer", "minimum": 1, "maximum": 4 },
          "update_cadence": { "type": "string" },
          "last_reviewed": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$|^YYYY-MM-DD$" },
          "promotion_eligible": {},
          "artifact_allowed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "artifact_disallowed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "bias_scope": { "type": "string" },
          "historical_use_notes": { "type": "string" },
          "transcript_policy": { "type": "string" },
          "notes": { "type": "string" },
          "corroboration_notes": { "type": "string" },
          "review_trigger": { "type": "string" }
        }
      }
    },
    "review_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule": { "type": "string" }
        },
        "required": ["rule"]
      }
    },
    "maintenance": {
      "type": "object",
      "properties": {
        "review_cadence": { "type": "string" },
        "prune_when": { "type": "array", "items": { "type": "string" } },
        "healthy_when": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
