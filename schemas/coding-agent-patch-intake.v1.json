{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grace-mar.local/schemas/coding-agent-patch-intake.v1.json",
  "title": "CodingAgentPatchIntake",
  "$comment": "Structured input for coding_agent_patch_intake.py — see docs/mcp/coding-agent-patch-intake.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "task",
    "repo",
    "files_touched",
    "tests",
    "risks",
    "review_request"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "agent": { "$ref": "#/$defs/agent" },
    "task": { "$ref": "#/$defs/task" },
    "repo": { "$ref": "#/$defs/repo" },
    "files_touched": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file_touched" }
    },
    "tests": { "$ref": "#/$defs/tests" },
    "risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "review_request": { "$ref": "#/$defs/review_request" }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["coding_agent", "assistant", "script", "operator"]
        },
        "model": { "type": "string", "minLength": 1 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "operator_intent", "claimed_summary"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "operator_intent": { "type": "string", "minLength": 1 },
        "claimed_summary": { "type": "string", "minLength": 1 }
      }
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "base_ref"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_ref": { "type": "string", "minLength": 1 },
        "head_ref": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 }
      }
    },
    "file_touched": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "change_type"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "change_type": {
          "type": "string",
          "enum": ["added", "modified", "deleted", "renamed", "generated", "unknown"]
        },
        "surface_hint": { "type": "string" }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimed", "reported_results"],
      "properties": {
        "claimed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reported_results": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "not_run_reason": { "type": "string", "minLength": 1 }
      }
    },
    "review_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desired_action", "requires_human_review"],
      "properties": {
        "desired_action": {
          "type": "string",
          "enum": ["review_only", "stage_candidate", "reject", "needs_more_info"]
        },
        "requires_human_review": { "type": "boolean" }
      }
    }
  }
}
