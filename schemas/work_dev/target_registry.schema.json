{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "work_dev_target_registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "segments"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "buyer_role", "status", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "label": { "type": "string" },
          "buyer_role": { "type": "string" },
          "status": { "type": "string" },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
