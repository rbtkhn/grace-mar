{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "work_dev_known_gaps",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "area", "problem", "status", "related_integration_ids", "notes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "area": { "type": "string" },
          "problem": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "closed", "planned", "partial"] },
          "related_integration_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
