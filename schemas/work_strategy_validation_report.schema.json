{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grace-mar.local/schemas/work_strategy_validation_report.schema.json",
  "title": "WorkStrategyValidationReport",
  "description": "Derived validation report from validate_strategy_packet.py — WORK-only; not Record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "lane",
    "target",
    "validators",
    "summary",
    "record_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "work-strategy-validation-report.v1"
    },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "const": "work-strategy" },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "task": { "type": ["string", "null"] },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gate_snippet": { "type": ["string", "null"] },
        "validation_out": { "type": ["string", "null"] }
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "status", "details", "subject_paths"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "needs_review"]
          },
          "details": { "type": "string" },
          "subject_paths": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "passed", "failed", "needs_review", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "needs_review"]
        },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "needs_review": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "record_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_paths_written", "canonical_write_violation", "notes"],
      "properties": {
        "canonical_paths_written": {
          "type": "array",
          "items": { "type": "string" }
        },
        "canonical_write_violation": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
