{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/skill_write/write_claims.schema.json",
  "title": "skill_write_claims",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "claims"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "ssot_note": {
      "type": "string",
      "description": "Operator WRITE claims — public-copy capability evidence, not companion Record."
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "claim",
          "capability_type",
          "level",
          "evidence_refs",
          "first_observed",
          "last_updated",
          "confidence",
          "promotion_candidate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^WRITE-[0-9]{3,}$"
          },
          "claim": { "type": "string", "minLength": 1 },
          "capability_type": {
            "type": "string",
            "enum": [
              "public-copy-adaptation",
              "surface-trim",
              "lede-craft",
              "closer-craft",
              "density-control",
              "voice-preservation",
              "shipping-discipline",
              "argument-compression",
              "audience-calibration"
            ]
          },
          "level": {
            "type": "string",
            "enum": ["exposed", "emerging", "consistent", "transferable", "independent"]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(DRAFT|POST|WRITE|ACT|READ)-[0-9a-zA-Z-]+$"
            }
          },
          "first_observed": { "type": "string", "format": "date" },
          "last_updated": { "type": "string", "format": "date" },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "promotion_candidate": { "type": "boolean" },
          "notes": { "type": "string" },
          "test_type": {
            "type": "string",
            "enum": [
              "surface_trim",
              "lede_test",
              "closer_test",
              "density_control",
              "voice_preservation",
              "shipping_check"
            ]
          },
          "test_date": { "type": "string", "format": "date" },
          "test_result": {
            "type": "string",
            "enum": ["pass", "partial", "fail"]
          },
          "target_surface": {
            "type": "string",
            "enum": ["locals", "x", "youtube_comment", "general"]
          },
          "scaffolding_level": {
            "type": "string",
            "enum": ["full_template", "hints_only", "none"]
          },
          "sample_ref": { "type": "string" },
          "failure_mode_notes": { "type": "string" },
          "next_test": { "type": "string" }
        }
      }
    }
  }
}
