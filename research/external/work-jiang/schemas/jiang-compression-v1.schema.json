{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grace-mar.local/schemas/jiang-compression-v1.json",
  "title": "Jiang compression artifact v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "userId",
    "title",
    "category",
    "compressedAt",
    "oneSentenceSummary",
    "executableNextActions",
    "linkedEvidence"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "userId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["operational", "analytical", "synthesis", "other"]
    },
    "compressedAt": { "type": "string", "minLength": 10 },
    "sourceLength": { "type": "integer", "minimum": 0 },
    "compressedLength": { "type": "integer", "minimum": 0 },
    "coreFactsReferenced": { "type": "array", "items": { "type": "string" } },
    "oneSentenceSummary": { "type": "string", "minLength": 1 },
    "executableNextActions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1 }
    },
    "linkedEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "intentLink": { "type": ["string", "null"] },
    "sourceExcerpt": { "type": "string" },
    "outputPath": { "type": "string" }
  },
  "description": "Operator compression pack for work-jiang. Target full JSON file under ~800 characters when practical.",
  "x-grace-mar-target-serialized-chars": 800
}
